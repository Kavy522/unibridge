{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "sum(rate(unibridge_http_requests_total[5m]))", "legendFormat": "requests/sec", "refId": "A" }],
      "title": "API request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(unibridge_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "A" }],
      "title": "API p95 latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [{ "expr": "sum(rate(unibridge_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(unibridge_http_requests_total[5m]))", "legendFormat": "5xx rate", "refId": "A" }],
      "title": "API error rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, route) (rate(unibridge_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}", "refId": "A" }],
      "title": "p95 latency by API route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "targets": [{ "expr": "topk(10, sum by (feature, role) (increase(unibridge_feature_use_total[7d])))", "legendFormat": "{{feature}} ({{role}})", "refId": "A" }],
      "title": "Most-used features (7 days)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(unibridge_db_query_duration_seconds_bucket[5m])))", "legendFormat": "{{operation}}", "refId": "A" }],
      "title": "Database query p95 by SQL operation",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "targets": [{ "expr": "unibridge_process_resident_memory_bytes", "legendFormat": "API memory", "refId": "A" }],
      "title": "API process memory",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["unibridge", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "UniBridge API Overview",
  "uid": "unibridge-api-overview",
  "version": 1
}
