# Copy to observability/alloy/.env for local testing, or set these as
# environment variables / secrets on your agent host (Railway, Fly.io, …).
# NEVER commit the filled-in .env — it holds the API key.

# Render backend host, WITH port 443, WITHOUT https:// or /metrics
RENDER_HOST=unibridge-api.onrender.com:443

# Same value you set as METRICS_TOKEN on the Render backend
METRICS_TOKEN=replace-with-a-long-random-string

# From Grafana Cloud → your stack → Prometheus → "Send Metrics" / Details:
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=123456
GRAFANA_CLOUD_API_KEY=glc_replace_with_cloud_access_policy_token
